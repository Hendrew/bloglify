{
  "name": "app",
  "private": true,
  "scripts": {
    "build": "bun bun.config.js",
    "build:css:front:compile": "sass ./app/assets/stylesheets/front.scss:./app/assets/builds/front.css --no-source-map --load-path=node_modules",
    "build:css:front:prefix": "postcss ./app/assets/builds/front.css --use=autoprefixer --output=./app/assets/builds/front.css",
    "build:css:backoffice:compile": "sass ./app/assets/stylesheets/backoffice.scss:./app/assets/builds/backoffice.css --no-source-map --load-path=node_modules",
    "build:css:backoffice:prefix": "postcss ./app/assets/builds/backoffice.css --use=autoprefixer --output=./app/assets/builds/backoffice.css",
    "build:css": "bun run build:css:front:compile && bun run build:css:front:prefix && bun run build:css:backoffice:compile && bun run build:css:backoffice:prefix",
    "watch:css": "nodemon --watch ./app/assets/stylesheets/ --ext scss --exec \"bun run build:css\""
  },
  "dependencies": {
    "@hotwired/stimulus": "^3.2.2",
    "@hotwired/turbo-rails": "^8.0.23",
    "@popperjs/core": "^2.11.8",
    "autoprefixer": "^10.5.0",
    "bootstrap": "^5.3.8",
    "bootstrap-icons": "^1.13.1",
    "nodemon": "^3.1.14",
    "postcss": "^8.5.15",
    "postcss-cli": "^11.0.1",
    "sass": "^1.101.0"
  },
  "browserslist": [
    "defaults"
  ]
}
