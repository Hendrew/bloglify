<% if record.errors.any? %>
<div class="alert alert-danger m-0 mb-5">
  <h3 class="h5 m-0">Desculpe, mas não foi possível salvar:
  <%= record.errors.count %>
  <%= record.errors.count == 1 ? "erro" : "erros" %></h3>

  <ul class="pt-2 pb-0 m-0">
    <% record.errors.each do |error| %>
      <li><%= error.full_message %></li>
    <% end %>
  </ul>
</div>
<% end %>
