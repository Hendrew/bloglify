<div class="container">
  <div class="page_header border-bottom py-5 d-flex justify-content-between align-items-center">
    <h2 class="p-0 m-0">Artigos</h2>

    <nav class="action_buttons">
      <%= link_to "Novo", new_backoffice_article_path, class: "btn btn-outline-primary", alt: "new" %>
    </nav>
  </div>

  <div class="page_body py-5">
    <div class="table-responsive">
      <table class="table table-bordered mb-0">
        <thead>
          <tr>
            <th>Título</th> <th>Autor</th> <th>Status</th> <th colspan="2">Data</th>
          </tr>
        </thead>

        <tbody>
          <% @articles.each do |article| %>
            <%= render article %>
          <% end %>

          <% if @articles.length.zero? %>
            <tr>
              <td colspan="4">Nenhum artigo encontrado.</td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>

    <% if @articles.length.positive? %>
    <div class="py-5">
      <%= @pagy.series_nav(:bootstrap).html_safe %>
    </div>
    <% end %>
  </div>
</div>
