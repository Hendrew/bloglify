<!DOCTYPE html>
<html lang="pt-br">
  <head>
    <title><%= content_for(:title) || "Bloglify" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Bloglify">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag "backoffice", "data-turbo-track": "reload" %>
    <%= javascript_include_tag "backoffice", "data-turbo-track": "reload", type: "module" %>
  </head>

  <body class="bg-dark">
    <%= render partial: "layouts/backoffice/shared/nav" %>
    <%= render partial: "layouts/backoffice/shared/flash" %>
    <main class="bg-white">
      <%= yield %>
    </main>
    <%= render partial: "layouts/backoffice/shared/footer" %>
  </body>
</html>
